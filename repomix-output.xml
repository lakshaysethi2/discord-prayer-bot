        <button type="submit" name="action" value="pause">⏸ Pause</button>
        <button type="submit" name="action" value="resume">▶ Resume</button>
    </form>
    {% endfor %}
    </p>
</div>
{% endif %}

<p><small>Live apply uses <code>apply_server_config</code> from <code>discord-radio</code> framework.</small></p>
</body>
