<file path="docker-compose.yml">
version: "3.9"

services:
  bot:
    build: .
    container_name: prayer-bot
    volumes:
      - ./data:/app/data
      - ./media/prayers:/app/media/prayers
    environment:
      - DISCORD_BOT_TOKEN=${DISCORD_BOT_TOKEN}
      - ADMIN_TOKEN=${ADMIN_TOKEN:-dev-token-change-me}
      - DATABASE_PATH=/app/data/prayer_bot.db
      - PYTHONPATH=/app
    restart: unless-stopped
    command: python bot/main.py

  dashboard:
    build: .
    container_name: prayer-dashboard
    ports:
      - "8700:8000"
    volumes:
      - ./data:/app/data
    environment:
      - DATABASE_PATH=/app/data/prayer_bot.db
      - PYTHONPATH=/app
      - ADMIN_TOKEN=${ADMIN_TOKEN:-dev-token-change-me}
    restart: unless-stopped
    command: uvicorn dashboard.app:app --host 0.0.0.0 --port 8000
